{
  "version": 2,
  "name": "sushma-lama-offensive-security",
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static-build"
    },
    {
      "src": "*.css",
      "use": "@vercel/static-build"
    },
    {
      "src": "*.js",
      "use": "@vercel/static-build"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}